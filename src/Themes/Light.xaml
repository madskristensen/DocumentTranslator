    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#8A8A8A"/>
    <SolidColorBrush x:Key="WarningTextBrush" Color="#B26200"/>

    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="Transparent"/>
