<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="AccentBrush" Color="#0067C0"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#0078D4"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#005A9E"/>
    <SolidColorBrush x:Key="AccentDisabledBrush" Color="#C7C7C7"/>
    <SolidColorBrush x:Key="AccentTextBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="AccentSubtleBackgroundBrush" Color="#E1EFFC"/>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F3F3F3"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="#E5E5E5"/>
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#FFFFFF"/>
