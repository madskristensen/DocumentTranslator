<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="AccentBrush" Color="#4CC2FF"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#47B1E8"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#42A1D2"/>
    <SolidColorBrush x:Key="AccentDisabledBrush" Color="#3A3A3A"/>
    <SolidColorBrush x:Key="AccentTextBrush" Color="#000000"/>
    <SolidColorBrush x:Key="AccentSubtleBackgroundBrush" Color="#0F3A5C"/>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#202020"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#2B2B2B"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="#1A1A1A"/>
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="ControlBackgroundDisabledBrush" Color="#262626"/>
    <SolidColorBrush x:Key="ControlBorderBrush" Color="#4A4A4A"/>
    <SolidColorBrush x:Key="ControlHoverBorderBrush" Color="#6A6A6A"/>
    <SolidColorBrush x:Key="SubtleBackgroundBrush" Color="#3A3A3A"/>
    <SolidColorBrush x:Key="SubtleHoverBackgroundBrush" Color="#454545"/>

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F2F2F2"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#B0B0B0"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#7E7E7E"/>
    <SolidColorBrush x:Key="WarningTextBrush" Color="#FFB454"/>

    <SolidColorBrush x:Key="ScrollBarTrackBrush" Color="Transparent"/>
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#5A5A5A"/>
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#7A7A7A"/>
    <SolidColorBrush x:Key="ScrollBarThumbPressedBrush" Color="#9A9A9A"/>

</ResourceDictionary>
