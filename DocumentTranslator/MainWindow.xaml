<Window x:Class="DocumentTranslator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DocumentTranslator"
        mc:Ignorable="d"
        Title="Document Translator" Height="640" Width="640"
        Icon="Assets/AppIcon.ico"
        AllowDrop="True"
        PreviewDragOver="Window_PreviewDragOver"
        Drop="Window_Drop"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Document Translator" FontSize="20" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>
            <Button Grid.Column="1" x:Name="SettingsButton" Width="32" Height="32"
                    ToolTip="Settings" Click="SettingsButton_Click"
                    Background="Transparent" BorderThickness="0" Cursor="Hand">
                <TextBlock Text="&#x2699;" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Button>
        </Grid>

        <TextBlock Grid.Row="1" Text="Source document" FontWeight="SemiBold"/>
        <Grid Grid.Row="2" Margin="0,4,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="FilePathBox" Grid.Column="0" IsReadOnly="True"/>
            <Button x:Name="BrowseButton" Grid.Column="1" Content="Browse..." Width="100" Margin="8,0,0,0"
                    Click="BrowseButton_Click"/>
        </Grid>

        <TextBlock Grid.Row="3" Text="Source language" FontWeight="SemiBold"/>
        <ComboBox Grid.Row="4" x:Name="SourceLanguageBox" Margin="0,4,0,4"
                  DisplayMemberPath="DisplayName" IsEditable="False"/>
        <TextBlock Grid.Row="5" Margin="0,0,0,12" Foreground="DarkOrange" TextWrapping="Wrap"
                   Text="Tip: specifying the source language is recommended over Auto-detect for best quality."/>

        <TextBlock Grid.Row="6" Text="Target languages (pick one or more)" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <ListBox Grid.Row="7" x:Name="TargetLanguagesList" SelectionMode="Multiple"
                 DisplayMemberPath="DisplayName"/>

        <StackPanel Grid.Row="8" Orientation="Horizontal" Margin="0,12,0,0">
            <Button x:Name="TranslateButton" Content="Translate" Width="120" Margin="0,0,8,0" Click="TranslateButton_Click"/>
        </StackPanel>

        <ListBox Grid.Row="9" x:Name="ProgressList" Margin="0,12,0,0" Height="140"/>
    </Grid>
</Window>
